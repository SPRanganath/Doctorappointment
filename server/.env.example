# Neon PostgreSQL connection string
# Get this from your Neon project dashboard -> Connection Details
# Format: postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/neondb?sslmode=require

# Port the Express server listens on
PORT=5000

# Secret Better Auth uses to sign sessions/cookies — replace with a long random string
BETTER_AUTH_SECRET=replace-this-with-a-long-random-secret

# Public URL of this API server (Better Auth uses this as its base URL)
BETTER_AUTH_URL=http://localhost:5000

# Comma-separated list of allowed frontend origins for CORS + Better Auth trustedOrigins
CORS_ORIGIN=http://localhost:5173
